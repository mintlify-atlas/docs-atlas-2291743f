  "keyFeatures": [
    "Debug failed Soroban transactions with detailed error traces",
    "Interactive trace viewer with search and navigation",
    "Performance profiling with interactive flamegraphs",
    "Source code mapping from WASM to Rust",
    "Local transaction replay and simulation",
    "Offline analysis with caching",
    "Session management for complex workflows",
    "Audit log signing with HSM support",
    "Error suggestions and heuristics",
    "GitHub source code linking"
  ],
  "publicApiSurface": [
    "erst debug <transaction-hash>",
    "erst debug --interactive",
    "erst debug --profile",
    "erst trace <transaction-hash>",
    "erst session list",
    "erst session save",
    "erst cache status",
    "erst cache clear",
    "erst audit:sign",
    "erst doctor",
    "erst compare",
    "erst export",
    "erst init",
    "erst upgrade"
  ]
